<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ==================== 头部 ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="40sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS Alert"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="短信警报控制台"
                android:textSize="13sp"
                android:textColor="#999999" />
        </LinearLayout>

        <!-- ==================== 状态 ==================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="状态"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="20dp"
            android:divider="@drawable/divider"
            android:showDividers="middle"
            android:elevation="1dp">

            <!-- 服务状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minHeight="40dp">

                <ImageView
                    android:id="@+id/ivIconService"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="服务状态"
                    android:textSize="13sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="运行中"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="6dp" />

                <Switch
                    android:id="@+id/swServiceToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="#D32F2F"
                    android:scaleX="0.8"
                    android:scaleY="0.8" />
            </LinearLayout>

            <!-- 短信权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minHeight="40dp">

                <ImageView
                    android:id="@+id/ivIconSmsReceive"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="短信权限"
                    android:textSize="13sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvSmsReceivePerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已授权"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC" />
            </LinearLayout>

            <!-- 通知权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minHeight="40dp">

                <ImageView
                    android:id="@+id/ivIconNotification"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="通知权限"
                    android:textSize="13sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvSmsReadPerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已授权"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC" />
            </LinearLayout>

            <!-- 悬浮窗权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minHeight="40dp">

                <ImageView
                    android:id="@+id/ivIconOverlay"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="悬浮窗权限"
                    android:textSize="13sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvNotificationPerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已授权"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC" />
            </LinearLayout>

            <!-- 电池优化 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:minHeight="40dp">

                <ImageView
                    android:id="@+id/ivIconBattery"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="电池优化"
                    android:textSize="13sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvOverlayPerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已授权"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== 关键词 ==================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关键词"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:id="@+id/llKeywordsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- 输入行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etNewKeyword"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="输入关键词..."
                android:textColorHint="#BBBBBB"
                android:textColor="#212121"
                android:textSize="14sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAddKeyword"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="添加"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_add"
                android:stateListAnimator="@null"
                android:elevation="0dp" />
        </LinearLayout>

        <!-- ==================== 测试按钮 ==================== -->
        <Button
            android:id="@+id/btnTestAlert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试警报"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_test"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnViewLog"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="查看运行日志"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/bg_button_add"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:layout_marginBottom="20dp" />

        <!-- ==================== 重要设置 ==================== -->
        <LinearLayout
            android:id="@+id/llImportantSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_warning_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/llSettingsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚠ 重要设置"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F57F17" />

                <TextView
                    android:id="@+id/tvSettingsArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="18sp"
                    android:textColor="#F57F17" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llSettingsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="在小米、华为、OPPO、vivo 等品牌手机上，请务必进行以下手动配置以防后台休眠：\n\n1. 开启【自启动】与【关联启动】\n2. 电池策略设为【无限制】\n3. 开启【悬浮窗】或【后台弹出界面】权限\n4. 开启【锁屏通知】与【悬浮通知】"
                    android:textSize="11sp"
                    android:textColor="#795548"
                    android:lineSpacingMultiplier="1.3" />

                <Button
                    android:id="@+id/btnRequestPermissions"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:text="一键申请权限"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="@drawable/bg_button_add"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:layout_marginTop="10dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
